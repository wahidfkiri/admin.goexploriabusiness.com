{
    "name": "vendor/ads-manager",
    "description": "A Laravel package for managing advertisements on establishment pages (like Google AdSense)",
    "type": "library",
    "autoload": {
        "psr-4": {
            "Vendor\\AdsManager\\": "src/"
        }
    },
    "require": {
        "php": "^8.0",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/console": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0",
        "illuminate/view": "^10.0|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vendor\\AdsManager\\AdsManagerServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
